import breeze.linalg._
import breeze.plot._
import com.github.tototoshi.csv._
import java.io.File

object NSELinePlot16 {

  def main(args: Array[String]): Unit = {

    val reader = CSVReader.open(new File("National_Stock_Exchange_of_India_Ltd.csv"))
    val data = reader.allWithHeaders()
    reader.close()

    val ltpValues = data.flatMap { row =>
      try {
        Some(row("LTP").replace(",", "").toDouble)
      } catch {
        case _: Throwable => None
      }
    }

    println("Rows Read: " + ltpValues.length)

    val x = DenseVector((1 to ltpValues.length).map(_.toDouble).toArray)
    val y = DenseVector(ltpValues.toArray)

    val fig = Figure("NSE Stock Prices")
    val plt = fig.subplot(0)

    plt += plot(x, y, name = "LTP", colorcode = "blue")

    plt.title = "National Stock Exchange - LTP"
    plt.xlabel = "Stock Number"
    plt.ylabel = "Last Traded Price (LTP)"

    fig.refresh()
  }
}
